# ── 基础配置 ──
ZHUYI_AUTH_SECRET=change-me
ZHUYI_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ── 存储 ──
# 留空则使用 backend/storage/ 下的子目录
# AutoDL 示例: ZHUYI_DATA_DIR=/root/autodl-tmp/zhuyi-data
ZHUYI_DATA_DIR=

# ── 数据库 ──
# 留空则使用 backend/data/zhuyi.db
ZHUYI_SQLITE_PATH=

# ── 重建管线 ──
ZHUYI_RECONSTRUCTION_MODE=mock
ZHUYI_RECON_PYTHON=/root/miniconda3/bin/python
ZHUYI_GAUSSIAN_SPLATTING_DIR=/root/gaussian-splatting
ZHUYI_RECON_ITERATIONS=10000
ZHUYI_RECON_IMAGE_LIMIT=300
ZHUYI_RECON_MIN_IMAGES=3
ZHUYI_COLMAP_NO_GPU=1

# ── DeepSeek AI 对话 ──
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30
DEEPSEEK_MAX_TOKENS=700
DEEPSEEK_TEMPERATURE=0.6
DEEPSEEK_HISTORY_LIMIT=8
